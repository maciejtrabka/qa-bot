# Skopiuj do pliku `.env` w tym katalogu (`cp .env.example .env`) i uzupełnij wartości.
# Plik `.env` jest w `.gitignore` — nie commituj go.
#
# Lokalnie OPENROUTER_API_KEY jest potrzebny tylko wtedy, gdy uruchamiasz z dysku
# skrypt / narzędzie wołające OpenRouter. Sam workflow w GitHub Actions używa
# sekretu OPENROUTER_API_KEY w ustawieniach repozytorium — bez pliku `.env`.

# OpenRouter — https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Opcjonalnie: inny host niż domyślny http://127.0.0.1:9333 (np. publiczny preview)
# BASE_URL=https://example.com

# Prompt QA — albo plik (domyślnie pr-agent-qa-prompt.md), albo inline (nadpisuje plik):
# PR_AGENT_PROMPT_FILE=pr-agent-qa-prompt.md
# PR_AGENT_PROMPT="Twoja instrukcja testów w jednej linii lub wieloliniowo w shellu"
